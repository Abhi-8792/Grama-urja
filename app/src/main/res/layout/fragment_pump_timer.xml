<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F1F8E9">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🌾 Pump Timer"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1B5E20"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Calculate how long to run your pump"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginBottom="24dp"/>

        <!-- Input Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <!-- Crop Selection -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Your Crop:"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerCrop"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_border"
                    android:padding="10dp"/>

                <!-- Land Size -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Land Size (in acres):"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <EditText
                    android:id="@+id/etAcres"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. 2.5"
                    android:inputType="numberDecimal"
                    android:textSize="16sp"
                    android:padding="10dp"
                    android:background="@drawable/edittext_border"/>

                <!-- Pipe Size -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pipe Size (inches):"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="8dp"/>

                <Spinner
                    android:id="@+id/spinnerPipeSize"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/edittext_border"
                    android:padding="10dp"/>

                <!-- Pipe size info -->
                <TextView
                    android:id="@+id/tvPipeInfo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ℹ️ Flow rate: -- litres/min"
                    android:textSize="13sp"
                    android:textColor="#1976D2"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="8dp"/>

                <Button
                    android:id="@+id/btnCalculate"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="CALCULATE PUMP TIME"
                    android:textSize="15sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#1B5E20"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Result Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:background="#E8F5E9"
                android:gravity="center">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="✅ Recommended Pump Time"
                    android:textSize="15sp"
                    android:textColor="#1B5E20"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tvPumpMinutes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="90"
                    android:textSize="64sp"
                    android:textStyle="bold"
                    android:textColor="#1B5E20"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MINUTES"
                    android:textSize="16sp"
                    android:textColor="#2E7D32"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#C8E6C9"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"/>

                <!-- Detail breakdown -->
                <TextView
                    android:id="@+id/tvResultCrop"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌾 Crop: Rice / Paddy"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvResultAcres"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📐 Land: 1.0 acre"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvResultPipe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔧 Pipe: 1 inch"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvResultFlow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💧 Flow Rate: 150 L/min"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/tvResultWater"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🪣 Total Water: 13,500 L"
                    android:textSize="14sp"
                    android:textColor="#2E7D32"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Crop Guide Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📊 Crop Water Guide (per acre)"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🌾 Rice / Paddy   →  1350 L\n🌿 Sugarcane      →  1800 L\n🌱 Cotton             →    900 L\n🌾 Wheat             →    675 L\n🥦 Vegetables     →    450 L\n🥜 Groundnut     →    750 L\n🍌 Banana            →  1125 L"
                    android:textSize="13sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="6dp"
                    android:fontFamily="monospace"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Pipe Guide Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:background="#FFFFFF">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🔧 Pipe Size Flow Guide"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="#212121"
                    android:layout_marginBottom="10dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="½ inch   →   40  L/min\n1 inch    → 150  L/min\n2 inch    → 400  L/min\n3 inch    → 800  L/min\n4 inch    → 1500 L/min"
                    android:textSize="13sp"
                    android:textColor="#616161"
                    android:lineSpacingExtra="6dp"
                    android:fontFamily="monospace"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </LinearLayout>
</ScrollView>